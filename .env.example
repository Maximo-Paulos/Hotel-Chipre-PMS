# ═══════════════════════════════════════════════════════════════════
# DEVELOPMENT (SQLite local)
# ═══════════════════════════════════════════════════════════════════
DATABASE_URL=sqlite:///./dev-local.db
APP_BASE_URL=http://127.0.0.1:8040
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://127.0.0.1:8040/api
VITE_PUBLIC_SITE_URL=https://hoteles-pms.com
VITE_PUBLIC_APP_URL=https://app.hoteles-pms.com
VITE_PUBLIC_APP_HOSTNAME=app.hoteles-pms.com
VITE_ALLOW_INDEXING=false

# ═══════════════════════════════════════════════════════════════════
# PRODUCTION — Supabase PostgreSQL
# Obtené la URL en: Project Settings > Database > Connection string
# Formato "URI mode" (usar el puerto 5432 directo o 6543 para pooler)
# ═══════════════════════════════════════════════════════════════════
# DATABASE_URL=postgresql+psycopg2://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# APP_BASE_URL=https://<tu-servicio>.onrender.com
# FRONTEND_URL=https://app.hoteles-pms.com

# Auth — generá con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=cambia-esto-antes-de-deploy

# PIN de manager (mínimo 6 dígitos, distinto de 1234)
MANAGER_PIN=123456

# Clave Fernet para cifrar credentials de integraciones (PayPal, MercadoPago, Gmail)
# Solo es obligatoria si activas alguna de esas integraciones en producción.
# Generá con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# INTEGRATIONS_ENCRYPTION_KEY=

# CORS — URLs del frontend público y app en Vercel
# CORS_ORIGINS=https://hoteles-pms.com,https://app.hoteles-pms.com

# Email transaccional del sistema
EMAIL_PROVIDER=resend
RESEND_API_KEY=
SYSTEM_EMAIL_FROM="Hotel Chipre PMS <noreply@auth.hotels-pms.com>"
SYSTEM_EMAIL_REPLY_TO=hotelxpms@gmail.com

# Pagos (opcionales para MVP)
# MERCADOPAGO_WEBHOOK_SECRET solo es obligatorio si MP_ACCESS_TOKEN o las credenciales OAuth de Mercado Pago están configuradas.
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
MERCADOPAGO_WEBHOOK_SECRET=

# OAuth/redirect URLs solo se validan si la integración está realmente configurada.
PAYPAL_REDIRECT_URI=http://127.0.0.1:8040/api/integrations/oauth/paypal/callback
MERCADOPAGO_REDIRECT_URI=http://127.0.0.1:8040/api/integrations/oauth/mercadopago/callback

# Gmail OAuth sigue existiendo solo para integraciones de hotel, no para el mail del sistema.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://127.0.0.1:8040/api/integrations/oauth/gmail/callback

# OTA (opcionales)
BOOKING_USERNAME=
BOOKING_PASSWORD=
EXPEDIA_API_KEY=
EXPEDIA_HOTEL_ID=

# Analytics IA provider. Set AI_PROVIDER=gemma for your own rig or AI_PROVIDER=openai for OpenAI API.
AI_ENABLED=true
AI_PROVIDER=gemma
AI_BASE_URL=http://127.0.0.1:11434/v1/chat/completions
AI_MODEL=gemma2:2b
AI_API_KEY=
AI_TIMEOUT_SECONDS=20
AI_MAX_OUTPUT_TOKENS=1024
AI_TEMPERATURE=0.2
AI_STRICT_JSON=true
AI_MONTHLY_QUOTA=20

# Legacy Gemma variables remain supported by the global Gemma assistant.
GEMMA_ENABLED=false
GEMMA_PROVIDER=disabled
GEMMA_ENDPOINT_URL=
GEMMA_MODEL=
ANALYTICS_EXPORTS_DIR=C:\PROJECTO\Hotel-Chipre-PMS\var\exports\analytics
